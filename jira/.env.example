# =============================================================================
# Trackly — environment configuration
# Quick start:  cp .env.example .env  &&  docker compose up --build
# Open http://localhost:8080  and log in with the bootstrap admin below.
#
# Every value here is a WORKING LOCAL DEFAULT. Before exposing Trackly to
# anyone else, change at least: SECRET_KEY, BOOTSTRAP_ADMIN_PASSWORD,
# POSTGRES_PASSWORD, and set APP_ENV=production / DEBUG=false.
#
# Do NOT put "# comments" on the same line as a KEY=value — docker compose
# keeps them as part of the value. Comments must be on their own line.
# =============================================================================

# --- PostgreSQL --------------------------------------------------------------
# Leave POSTGRES_HOST as-is: under docker compose the backend/migrator services
# set it to "db" themselves. Only change it if running the backend outside Docker.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trackly
POSTGRES_USER=trackly
POSTGRES_PASSWORD=trackly

# Optional single-URL override. If set, it replaces the POSTGRES_* fields above.
# DATABASE_URL=postgresql+psycopg://trackly:trackly@localhost:5432/trackly

# --- Security ----------------------------------------------------------------
# SECRET_KEY is the ONLY auth-related secret that must live here: it signs JWTs
# and derives the key that encrypts every credential you store through the admin
# UI (mail/Jira/LDAP/Entra). Changing it invalidates sessions + stored secrets.
# In production replace with: openssl rand -hex 32
SECRET_KEY=local-dev-secret-change-me-0123456789abcdef
# Fallback token lifetime (minutes). The effective value is configurable in the
# admin UI under Administration -> Authentication; this is only the default.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Application -------------------------------------------------------------
# APP_ENV: development | production | test
APP_ENV=development
# DEBUG: set false in production
DEBUG=true
# Comma-separated browser origins allowed by CORS.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- File storage ------------------------------------------------------------
ATTACHMENTS_DIR=/data/attachments
MAX_ATTACHMENT_MB=25

# --- First-run bootstrap admin ----------------------------------------------
# Created automatically on first boot when the database has no users.
# Change the password before using Trackly for real.
BOOTSTRAP_ADMIN_EMAIL=admin@trackly.local
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin

# =============================================================================
# Jira, email, and external auth (LDAP / Entra ID) are NOT configured here.
# Instance admins manage them entirely through the web UI under
# "Administration": Jira Connections, Mail, Identity Providers, Authentication.
# Credentials are stored encrypted in the database. The migrator CLI reads the
# same UI-configured Jira connections (no JIRA_* env vars required).
# =============================================================================
