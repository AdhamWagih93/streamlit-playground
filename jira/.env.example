# =============================================================================
# Trackly — environment configuration
# Copy to `.env` and adjust:  cp .env.example .env
# The values below are SAFE DEV DEFAULTS. Change SECRET_KEY and the bootstrap
# admin password before exposing Trackly to anyone but yourself.
# =============================================================================

# --- PostgreSQL --------------------------------------------------------------
# POSTGRES_HOST defaults to localhost for bare-metal dev. Under docker compose
# the backend service overrides this to `db` automatically — leave it as-is.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trackly
POSTGRES_USER=trackly
POSTGRES_PASSWORD=trackly

# Optional: a full SQLAlchemy URL. If set, it OVERRIDES the discrete
# POSTGRES_* values above. Note the psycopg v3 driver scheme.
# DATABASE_URL=postgresql+psycopg://trackly:trackly@localhost:5432/trackly

# --- Security ----------------------------------------------------------------
# CHANGE THIS. Use a long random string, e.g.  openssl rand -hex 32
SECRET_KEY=change-me-in-production-please-32+chars
# Access token lifetime in minutes (default 1440 = 24h).
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Application -------------------------------------------------------------
# APP_ENV: development | production | test
APP_ENV=development
# DEBUG: set to false in production
DEBUG=true
# Comma-separated list of allowed browser origins for CORS.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- File storage ------------------------------------------------------------
# Where uploaded attachments are written. Mounted as a volume in compose.
ATTACHMENTS_DIR=/data/attachments
# Max single-attachment size in megabytes.
MAX_ATTACHMENT_MB=25

# --- First-run bootstrap admin ----------------------------------------------
# Created automatically on first boot if no users exist. CHANGE THE PASSWORD.
BOOTSTRAP_ADMIN_EMAIL=admin@trackly.local
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin

# =============================================================================
# Jira -> Trackly migration (only needed when running the migrator)
# =============================================================================
# Base URL of your Jira instance (no trailing slash).
JIRA_BASE_URL=https://your-org.atlassian.net
# Cloud auth (JIRA_AUTH_MODE=cloud): account email + API token (HTTP Basic).
# Server/DC auth (JIRA_AUTH_MODE=server): leave email blank, put your Personal
# Access Token in JIRA_API_TOKEN (sent as a Bearer token).
JIRA_EMAIL=you@your-org.com
JIRA_API_TOKEN=
# JIRA_AUTH_MODE: cloud | server
JIRA_AUTH_MODE=cloud
# Comma-separated project keys to import. Empty = every visible project.
JIRA_PROJECT_KEYS=
# Optional extra JQL AND-ed onto each project filter, e.g. updated >= -90d
JIRA_JQL=
# Verify the Jira server's TLS certificate (set false only for self-signed dev).
JIRA_VERIFY_SSL=true
