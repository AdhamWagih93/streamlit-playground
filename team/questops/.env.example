# Copy to .env next to docker-compose.yml. Everything has a demo-safe default.
# Keys are QO_-prefixed on the host side: compose maps QO_JIRA_USER -> JIRA_USER
# inside the container. (Same-named vars trigger a self-reference bug in
# podman-compose's ${VAR:-default} substitution.)

# demo mode = seeded users/board/jobs, no external calls except Ollama
QO_DEMO_MODE=true
QO_SECRET_KEY=change-me

# --- Host name resolution (so internal hostnames resolve in the container) ---
# The container has its own network namespace and does NOT inherit the host's
# /etc/hosts or DNS, which is why you may be forced to use IPs. By default the
# compose file bind-mounts the host's /etc/hosts read-only, so hostnames the
# host resolves via /etc/hosts work inside the container with no IPs.
#   - Override the hosts file path if yours is elsewhere:
QO_HOSTS_FILE=/etc/hosts
#   - If your endpoints come from CORPORATE DNS (or the host uses a
#     systemd-resolved stub at 127.0.0.53 the container can't reach), set the
#     real resolver(s)/search domain(s) and uncomment the dns:/dns_search:
#     lines in docker-compose.yml:
QO_DNS=
QO_DNS_SEARCH=

# --- AI (local Ollama) ---
# podman: host.containers.internal · docker: host.docker.internal
QO_OLLAMA_URL=http://host.containers.internal:11434
QO_OLLAMA_MODEL=llama3.1

# --- Jira Data Center (one project) ---
QO_JIRA_BASE_URL=https://jira.mycorp.local
QO_JIRA_USER=
QO_JIRA_PASSWORD=
QO_JIRA_PROJECT_KEY=DEVOPS
# board columns in flow order; Reopened issues appear in the first column
QO_JIRA_BOARD_STATUSES=Open,In Progress,Resolved,Closed
QO_JIRA_DONE_STATUSES=Closed
QO_JIRA_REVIEW_STATUSES=Resolved
QO_JIRA_REOPENED_STATUSES=Reopened
# Closed column shows only tickets closed within this many days
QO_JIRA_CLOSED_WINDOW_DAYS=30

# --- Jenkins ---
QO_JENKINS_URL=https://jenkins.mycorp.local
QO_JENKINS_USER=
QO_JENKINS_TOKEN=
# long-running = elapsed > job's avg runtime * factor (minutes = fallback when no history)
QO_JENKINS_LONG_RUNNING_FACTOR=1.5
QO_JENKINS_LONG_RUNNING_MINUTES=45
# only failures from the last N days; comma-separated path tokens to skip
QO_JENKINS_FAILURE_WINDOW_DAYS=14
QO_JENKINS_IGNORE=DevOps_Test

# --- Elasticsearch (Jenkins KPI + error analysis) ---
QO_ES_URL=https://es.mycorp.local:9200
QO_ES_API_KEY=
QO_ES_VERIFY_SSL=true
# may be a single index, a wildcard pattern, or a comma list — use a pattern
# when builds roll over into dated indices, e.g. ef-devops-jenkins-builds*
QO_JENKINS_KPI_INDEX=jenkins-kpi
QO_ERROR_ANALYSIS_INDEX=jenkins-error-analysis
# minute marks when the KPI loader runs (:05/:35) — countdown uses container TZ
QO_KPI_SYNC_MINUTES=5,35
# KPI panel reads the WHOLE time window (default: past week); per-request cap
QO_KPI_MAX_DOCS=10000
# which doc field(s) hold the build time (most-authoritative first) — the KPI
# window is applied on these. Change it if your index names the build timestamp
# differently; the panel's "why 0 builds?" diagnostics list the fields it found.
QO_KPI_DATE_FIELDS=builddate,@timestamp
# exclude KPI docs whose job path contains one of these tokens (the KPI
# sibling of QO_JENKINS_IGNORE — its own list on purpose)
QO_KPI_IGNORE=

# --- Upgrade checker: the ONLY outbound-internet calls QuestOps makes ---
# Latest versions come from Docker Hub, GitHub and Artifact Hub (NOT
# endoflife.date). Hosts behind a corporate proxy: set QO_UPGRADES_PROXY —
# internal Jira/Jenkins/ES/LDAP traffic never uses it. Point any *_API_BASE at
# an internal mirror if the public host is blocked in your region.
QO_UPGRADES_PROXY=
QO_UPGRADES_VERIFY_SSL=true
QO_DOCKERHUB_API_BASE=https://hub.docker.com/v2
QO_GITHUB_API_BASE=https://api.github.com
QO_ARTIFACTHUB_API_BASE=https://artifacthub.io/api/v1
QO_ERROR_ANALYSIS_DAYS=14
QO_TZ=UTC

# --- LDAP (login gated on group membership) ---
QO_LDAP_URL=ldaps://ldap.mycorp.local:636
QO_LDAP_BIND_DN=CN=svc-questops,OU=Service Accounts,DC=mycorp,DC=local
QO_LDAP_BIND_PASSWORD=
QO_LDAP_BASE_DN=OU=Users,DC=mycorp,DC=local
QO_LDAP_USER_ATTR=sAMAccountName
QO_LDAP_REQUIRED_GROUP=CN=devops-team,OU=Groups,DC=mycorp,DC=local
# everyone in the group is an approver EXCEPT these usernames (plain members)
QO_MEMBER_USERNAMES=
# NOTE: the above LDAP settings gate LOGIN only. Access Management resolves each
# project's [TEAM] group members by running an asset from your cloned Engine
# repository — scripts/Tools/LDAP/getTeamMembers.sh <team> — which sources a .prd
# profile via `. $HOME/.prd`. QuestOps runs it with HOME set to the Engine repo
# root, so .prd (committed at the repo root) is sourceable as $HOME/.prd inside
# the container. Just add the Engine repo on the Repositories page and clone it;
# no extra LDAP directories to configure.

# --- Repositories page ---
# repos are ADDED FROM THE UI; config only carries the ADO instance creds.
# git clone/pull uses USER + PASSWORD; the REST browse uses USER + PAT.
# Leave one empty and the other is used for both.
# ADO_URL is the INSTANCE root (NOT a collection) — collections are
# enumerated so the whole instance is browsed / access-audited.
QO_ADO_URL=https://ado.mycorp.local
QO_ADO_USER=svc-questops
QO_ADO_PASSWORD=
QO_ADO_PAT=
# usernames excluded from repo-specific-access analysis (repo creators/admins
# expected to hold access on every repo — like the service account)
QO_ADO_ACCESS_EXCLUDE=

# --- Git push for approved repo actions ---
QO_GIT_TOKEN=
QO_GIT_USER_NAME=questops-bot
QO_GIT_USER_EMAIL=questops-bot@mycorp.local
