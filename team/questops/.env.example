# Copy to .env next to docker-compose.yml. Everything has a demo-safe default.

# demo mode = seeded users/board/jobs, no external calls except Ollama
DEMO_MODE=true
SECRET_KEY=change-me

# --- AI (local Ollama) ---
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1

# --- Jira Data Center (one project) ---
JIRA_BASE_URL=https://jira.mycorp.local
JIRA_PAT=
JIRA_PROJECT_KEY=DEVOPS
JIRA_BOARD_STATUSES=To Do,In Progress,In Review,Done

# --- Jenkins ---
JENKINS_URL=https://jenkins.mycorp.local
JENKINS_USER=
JENKINS_TOKEN=
JENKINS_LONG_RUNNING_MINUTES=45

# --- LDAP (login gated on group membership) ---
LDAP_URL=ldaps://ldap.mycorp.local:636
LDAP_BIND_DN=CN=svc-questops,OU=Service Accounts,DC=mycorp,DC=local
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=OU=Users,DC=mycorp,DC=local
LDAP_USER_ATTR=sAMAccountName
LDAP_REQUIRED_GROUP=CN=devops-team,OU=Groups,DC=mycorp,DC=local
LDAP_APPROVER_GROUP=CN=devops-leads,OU=Groups,DC=mycorp,DC=local

# --- Git push for approved repo actions ---
GIT_TOKEN=
GIT_USER_NAME=questops-bot
GIT_USER_EMAIL=questops-bot@mycorp.local
