# Copy to .env next to docker-compose.yml. Everything has a demo-safe default.
# Keys are QO_-prefixed on the host side: compose maps QO_JIRA_USER -> JIRA_USER
# inside the container. (Same-named vars trigger a self-reference bug in
# podman-compose's ${VAR:-default} substitution.)

# demo mode = seeded users/board/jobs, no external calls except Ollama
QO_DEMO_MODE=true
QO_SECRET_KEY=change-me

# --- AI (local Ollama) ---
# podman: host.containers.internal · docker: host.docker.internal
QO_OLLAMA_URL=http://host.containers.internal:11434
QO_OLLAMA_MODEL=llama3.1

# --- Jira Data Center (one project) ---
QO_JIRA_BASE_URL=https://jira.mycorp.local
QO_JIRA_USER=
QO_JIRA_PASSWORD=
QO_JIRA_PROJECT_KEY=DEVOPS
# board columns in flow order; Reopened issues appear in the first column
QO_JIRA_BOARD_STATUSES=Open,In Progress,Resolved,Closed
QO_JIRA_DONE_STATUSES=Closed
QO_JIRA_REVIEW_STATUSES=Resolved
QO_JIRA_REOPENED_STATUSES=Reopened
# Closed column shows only tickets closed within this many days
QO_JIRA_CLOSED_WINDOW_DAYS=30

# --- Jenkins ---
QO_JENKINS_URL=https://jenkins.mycorp.local
QO_JENKINS_USER=
QO_JENKINS_TOKEN=
# long-running = elapsed > job's avg runtime * factor (minutes = fallback when no history)
QO_JENKINS_LONG_RUNNING_FACTOR=1.5
QO_JENKINS_LONG_RUNNING_MINUTES=45
# only failures from the last N days; comma-separated path tokens to skip
QO_JENKINS_FAILURE_WINDOW_DAYS=14
QO_JENKINS_IGNORE=DevOps_Test

# --- Elasticsearch (Jenkins KPI + error analysis) ---
QO_ES_URL=https://es.mycorp.local:9200
QO_ES_API_KEY=
QO_ES_VERIFY_SSL=true
QO_JENKINS_KPI_INDEX=jenkins-kpi
QO_ERROR_ANALYSIS_INDEX=jenkins-error-analysis
# minute marks when the KPI loader runs (:05/:35) — countdown uses container TZ
QO_KPI_SYNC_MINUTES=5,35
QO_ERROR_ANALYSIS_DAYS=14
QO_TZ=UTC

# --- LDAP (login gated on group membership) ---
QO_LDAP_URL=ldaps://ldap.mycorp.local:636
QO_LDAP_BIND_DN=CN=svc-questops,OU=Service Accounts,DC=mycorp,DC=local
QO_LDAP_BIND_PASSWORD=
QO_LDAP_BASE_DN=OU=Users,DC=mycorp,DC=local
QO_LDAP_USER_ATTR=sAMAccountName
QO_LDAP_REQUIRED_GROUP=CN=devops-team,OU=Groups,DC=mycorp,DC=local
# everyone in the group is an approver EXCEPT these usernames (plain members)
QO_MEMBER_USERNAMES=

# --- Repositories page ---
# repos are ADDED FROM THE UI; config only carries the ADO instance creds
# (used to browse repositories and to clone/pull — a PAT works as password)
QO_ADO_URL=https://ado.mycorp.local/DefaultCollection
QO_ADO_USER=svc-questops
QO_ADO_PASSWORD=

# --- Git push for approved repo actions ---
QO_GIT_TOKEN=
QO_GIT_USER_NAME=questops-bot
QO_GIT_USER_EMAIL=questops-bot@mycorp.local
