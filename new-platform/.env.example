# ============================================================================
# MERIDIAN configuration. Local dev needs NONE of this (defaults are demo+none).
# For deployment: copy to .env next to docker-compose.yml and fill in.
# ============================================================================

# ---- modes ----
DATA_MODE=live                  # demo | live
AUTH_MODE=entra                 # none | entra | ldap
# ALLOW_INSECURE_NO_AUTH=false  # required 'true' to run AUTH_MODE=none in a container

# ---- session ----
SESSION_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=true              # true when served over TLS

# ---- Entra ID (AUTH_MODE=entra) ----
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=https://your-host/api/auth/entra/callback
# JSON map of group id/name -> platform role (Admin|CLevel|Developer|QC|Operations)
ENTRA_GROUP_ROLE_MAP={"devops-admins":"Admin"}

# ---- LDAP (AUTH_MODE=ldap) ----
LDAP_URL=ldaps://dc.corp.example.com
LDAP_BIND_DN_TEMPLATE={username}@corp.example.com
LDAP_USER_SEARCH_BASE=DC=corp,DC=example,DC=com
LDAP_GROUP_ROLE_MAP={"devops-admins":"Admin","qc-engineers":"QC"}

# ---- Vault (credential broker for all live integrations) ----
VAULT_ADDR=https://vault.corp.example.com
VAULT_TOKEN=
# VAULT_TOKEN_FILE=/run/secrets/vault-token   # mounted file wins over VAULT_TOKEN
GIT_VAULT_PATH=new_git
JENKINS_VAULT_PATH=jenkins
POSTGRES_VAULT_PATH=postgres
PRISMA_S3_VAULT_PATH=s3
ADO_VAULT_PATH=ado

# ---- Elasticsearch ----
ES_HOSTS=https://es.corp.example.com:9200
ES_API_KEY=
ES_VERIFY_CERTS=false

# ---- misc (defaults match the original platform) ----
CICD_REPO_BASE=/tmp/meridian-repos
PRISMA_S3_BUCKET=PrismaCloud-Logs
POSTGRES_TABLE=devops_projects
DOCCHAT_OLLAMA_URL=http://ef-nexus-03:8081
DOCCHAT_MODEL=qwen3.5:9b
