# ============================================================================
# MERIDIAN configuration.
#
# Design: the ONLY external integration configured here is the platform's own
# PostgreSQL database. Every runtime integration (Elasticsearch, Jenkins,
# Azure DevOps, S3, LDAP directory, Ollama, Vault) is configured inside the
# app — Settings → Integrations — and stored ENCRYPTED in that database.
#
# Local dev needs NONE of this (defaults are demo + no-auth + optional local PG).
# ============================================================================

# ---- modes ----
DATA_MODE=live                  # demo | live
AUTH_MODE=entra                 # none | entra | ldap (login only; none refused in-container)
# ALLOW_INSECURE_NO_AUTH=false  # must be 'true' to run AUTH_MODE=none in a container

# ---- platform database (PostgreSQL 14+; compose bundles postgres:17) ----
# Option A — bundled DB (docker-compose "db" service): just set the password.
POSTGRES_PASSWORD=change-me
# Option B — EXISTING Postgres: set the full DSN (overrides the bundled DB).
# DATABASE_URL=postgresql://meridian:secret@db.corp.example.com:5432/meridian

# Encrypts integration configs at rest (Fernet key, 32-byte urlsafe base64).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY=

# ---- session ----
SESSION_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=true              # true when served over TLS

# ---- sign-in: Entra ID (AUTH_MODE=entra) ----
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=https://your-host/api/auth/entra/callback
# JSON map of group id/name -> platform role (Admin|CLevel|Developer|QC|Operations)
ENTRA_GROUP_ROLE_MAP={"devops-admins":"Admin"}

# ---- sign-in: LDAP (AUTH_MODE=ldap) ----
# (This is the LOGIN directory; the roster-sync directory is configured
#  separately in Settings → Integrations → Identity directory.)
LDAP_URL=ldaps://dc.corp.example.com
LDAP_BIND_DN_TEMPLATE={username}@corp.example.com
LDAP_USER_SEARCH_BASE=DC=corp,DC=example,DC=com
LDAP_GROUP_ROLE_MAP={"devops-admins":"Admin","qc-engineers":"QC"}
